{
  "name": "terminalfs",
  "version": "0.1.0",
  "description": "Terminal-style static-site framework - interactive terminal powered by Markdown",
  "type": "module",
  "main": "bin/terminalfs.js",
  "bin": {
    "terminalfs": "./bin/terminalfs.js"
  },
  "scripts": {
    "dev": "node bin/terminalfs.js dev",
    "build": "node bin/terminalfs.js build",
